# Copy to .env only when you need to override defaults.
POSTGRES_DB=metastore
POSTGRES_USER=hive
POSTGRES_PASSWORD=hive

HIVE_JDBC_PORT=10000
NAMENODE_UI_PORT=9870
YARN_UI_PORT=8088
SPARK_UI_PORT=4040
SPARK_HISTORY_UI_PORT=18080

# Spark Thrift Server driver stays in the thriftserver container.
SPARK_DRIVER_MEMORY=1g

# Executors are allocated by YARN across worker1, worker2 and worker3.
SPARK_EXECUTOR_INSTANCES=3
SPARK_EXECUTOR_CORES=1
SPARK_EXECUTOR_MEMORY=512m

